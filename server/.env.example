# 基本設定
APP_NAME=FileExplorer

# 安全加密設定
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 資料庫設定 (使用非同步 aiosqlite 驅動)
DATABASE_URL=sqlite+aiosqlite:////app/db/file_explorer.db
REDIS_URL=redis://redis:6379/0

# 檔案存儲設定
UPLOAD_DIR=/app/data/uploads
TEMP_DIR=/app/data/temp

# 初始管理員設定 (供 Step 1.3 初始化使用)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# 背景垃圾回收 (GC) 設定
UPLOAD_SESSION_EXPIRE_HOURS=24
GC_INTERVAL_SECONDS=3600

# Uvicorn 伺服器設定
APP_HOST=0.0.0.0
APP_PORT=8000

# Redis 連線設定
REDIS_MAX_CONNECTIONS=20

# 下載憑證相關參數 (VFS Download Ticket)
DOWNLOAD_TICKET_TTL=30
DOWNLOAD_TICKET_MAX_REQUESTS=4

# 檔案合併讀取緩衝區大小 (Byte，預設為 1MB)
FILE_MERGE_BUFFER_SIZE=1048576

# 2FA 綁定臨時權杖有效期限 (分鐘)
TWO_FA_SETUP_TOKEN_EXPIRE_MINUTES=5

# 2FA 重放防禦快取時效 (秒，預設 60 秒)
TWO_FA_REPLAY_TTL=60

# 目錄快取控制
VFS_DIRECTORY_CACHE_ENABLED=True
VFS_DIRECTORY_CACHE_TTL=3600

